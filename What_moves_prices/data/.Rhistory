View(df)
# Transform "na" to NaN and convert to numeric
df <- as.data.frame(lapply(df, function(x) {
as.numeric(ifelse(x == "na", NaN, x))
}))
View(df)
heatmap(df)
View(df)
heatmap(cor(df))
cor(df)
cor(df, how = "pairwise.complete.obs")
cor(df, use = "pairwise.complete.obs")
View(df)
