})
# Create a dataframe for plotting
plot_data <- data.frame(
Predictor = names(r_squared),
R2 = r_squared
)
# Plot using ggplot2
ggplot(plot_data, aes(x = reorder(Predictor, -R2), y = R2)) +
geom_bar(stat = "identity", fill = "steelblue") +
theme_minimal() +
labs(
title = "Explained Variance by Predictor",
x = "Predictor",
y = "R-squared"
)
names(df)[-length(names(df))]
r_squared
df <- data.frame(
Predictor1 = x_1,
Predictor2 = x_2,
Predictor3 = x_3,
Response = x_1+ x_2 +x_3 +rnorm(100)
)
# Fit a full model
full_model <- lm(Response ~ ., data = df); summary(full_model)
# Calculate R-squared for individual models
r_squared <- sapply(names(df)[-length(names(df))], function(predictor) {
model <- lm(as.formula(paste("Response ~", predictor)), data = df)
summary(model)$r.squared
})
